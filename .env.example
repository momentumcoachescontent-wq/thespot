# =============================================================
# THE SPOT — Variables de entorno (plantilla sin valores reales)
# Copia como .env y completa los valores antes de ejecutar.
# NUNCA versionar .env con valores reales.
# =============================================================

# VAPID public key para Web Push Notifications (requerida para que funcionen las notificaciones)
# Genera un par de claves con: npx web-push generate-vapid-keys
# La clave pública va aquí (frontend); la privada va en Supabase Secrets como VAPID_PRIVATE_KEY
# VITE_VAPID_PUBLIC_KEY=

# (Opcional) Webhook n8n para flujos de automatización
# El SOS usa WhatsApp directamente — este webhook es solo para
# integraciones adicionales de n8n si se reintroducen.
# VITE_N8N_WEBHOOK=https://TU_INSTANCIA_N8N/webhook/ENDPOINT
